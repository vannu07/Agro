{
  "projectId": "prj_uL53AHZ9uyZXGYxH0CFPEOdHI002",
  "orgId": "team_vannu07",
  "name": "Krishi Mitr - AI-Powered Smart Farming Assistant",
  "version": "1.0.0",
  "description": "A comprehensive AI and ML platform for Indian farmers providing crop recommendations, disease detection, fertilizer management, yield predictions, and sustainable farming guidance",
  "buildCommand": "cd app && pip install -r ../requirements.txt",
  "devCommand": "cd app && python app.py",
  "public": true,
  "framework": "flask",
  "runtime": "python3.11",
  "env": [
    {
      "key": "FLASK_ENV",
      "value": "production",
      "description": "Flask environment"
    },
    {
      "key": "FLASK_SECRET_KEY",
      "value": "your-secret-key-here",
      "description": "Flask session secret key (min 32 chars)"
    },
    {
      "key": "MONGODB_URI",
      "value": "mongodb+srv://username:password@cluster.mongodb.net/krishi_mitr",
      "description": "MongoDB Atlas connection string"
    },
    {
      "key": "AUTH0_DOMAIN",
      "value": "your-tenant.auth0.com",
      "description": "Auth0 domain"
    },
    {
      "key": "AUTH0_CLIENT_ID",
      "value": "your-client-id",
      "description": "Auth0 client ID"
    },
    {
      "key": "AUTH0_CLIENT_SECRET",
      "value": "your-client-secret",
      "description": "Auth0 client secret"
    },
    {
      "key": "WEATHER_API_KEY",
      "value": "your-weather-api-key",
      "description": "Weather API key from weatherapi.com"
    },
    {
      "key": "GEMINI_API_KEY",
      "value": "your-gemini-api-key",
      "description": "Google Gemini API key"
    }
  ],
  "regions": ["iad"],
  "functions": {
    "app/app.py": {
      "memory": 1024,
      "maxDuration": 60,
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/app.py"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/farm-iq(.*)",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "sourceMap": true,
  "tags": [
    "agriculture",
    "ai",
    "farming",
    "ml",
    "crop-management",
    "india",
    "sustainable-farming",
    "disease-detection",
    "yield-prediction"
  ],
  "keywords": [
    "Krishi Mitr",
    "agricultural AI",
    "crop recommendation",
    "disease detection",
    "fertilizer management",
    "yield prediction",
    "smart farming",
    "sustainable agriculture",
    "farmer assistant",
    "Indian agriculture"
  ],
  "features": {
    "authentication": {
      "provider": "auth0",
      "enabled": true,
      "description": "Auth0 authentication with custom user profiles"
    },
    "database": {
      "provider": "mongodb",
      "enabled": true,
      "description": "MongoDB Atlas for user data and activity logging"
    },
    "aiAgents": {
      "enabled": true,
      "agents": [
        {
          "name": "Crop Recommendation",
          "endpoint": "/crop-recommend",
          "model": "google-gemini",
          "description": "Recommends best crop based on soil, climate, and history"
        },
        {
          "name": "Disease Detection",
          "endpoint": "/disease-predict",
          "model": "custom-ml",
          "description": "Detects crop diseases from images"
        },
        {
          "name": "Fertilizer Suggestion",
          "endpoint": "/fertilizer",
          "model": "google-gemini",
          "description": "Suggests fertilizers based on crop and soil"
        },
        {
          "name": "Yield Prediction",
          "endpoint": "/yield",
          "model": "xgboost",
          "description": "Predicts crop yield based on historical data"
        },
        {
          "name": "Sustainability Advisor",
          "endpoint": "/sustainability",
          "model": "google-gemini",
          "description": "Provides sustainable farming practices and crop rotation"
        },
        {
          "name": "Smart Irrigation",
          "endpoint": "/irrigation",
          "model": "custom",
          "description": "Optimizes irrigation schedules based on weather"
        },
        {
          "name": "Market Trends",
          "endpoint": "/market-trends",
          "model": "data-analysis",
          "description": "Analyzes agricultural market trends"
        },
        {
          "name": "AI Assistant",
          "endpoint": "/api/assistant",
          "model": "google-gemini",
          "description": "General purpose farming assistant"
        }
      ]
    },
    "api": {
      "enabled": true,
      "endpoints": {
        "health": "/api/health",
        "agents": "/api/agents",
        "recommendations": "/api/recommendations",
        "predictions": "/api/predictions"
      }
    }
  },
  "pages": [
    {
