# ==========================================
# KRISHI MITR - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your actual values

# FLASK CONFIGURATION
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_SECRET_KEY=generate-a-random-secret-key-here-min-32-chars

# MONGODB ATLAS CONFIGURATION
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/krishi_mitr?retryWrites=true&w=majority
DATABASE_NAME=krishi_mitr

# AUTH0 CONFIGURATION (for user authentication)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id-from-auth0
AUTH0_CLIENT_SECRET=your-client-secret-from-auth0

# WEATHER API (for weather forecasting)
WEATHER_API_KEY=your-weatherapi-key-from-weatherapi.com

# GOOGLE GEMINI API (for AI Assistant)
GEMINI_API_KEY=your-google-gemini-api-key

# APPLICATION SETTINGS
PORT=5000
HOST=0.0.0.0
WORKERS=4

# OPTIONAL: ERROR TRACKING
SENTRY_DSN=optional-sentry-dsn-for-error-monitoring

# OPTIONAL: EMAIL NOTIFICATIONS
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
